generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id @default(uuid())
  name          String
  specification String?
  stockUnit     String?  @map("stock_unit")
  sku           String   @unique
  sellingPrice  Decimal  @map("selling_price")
  costPrice     Decimal  @map("cost_price")
  lowestPrice   Decimal? @map("lowest_price")
  imageUrl      String?  @map("image_url")
  category      String?
  quantity      String?
  createdAt     DateTime @default(now()) @map("created_at")

  transactions InventoryTransaction[]
  incidents    Incident[]

  @@map("products")
}

enum TransactionType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
}

model InventoryTransaction {
  id        String          @id @default(uuid())
  productId String          @map("product_id")
  type      TransactionType
  quantity  Int
  unitPrice Decimal?        @map("unit_price")
  deviceId  String          @map("device_id")
  createdAt DateTime        @default(now()) @map("created_at")
  syncedAt  DateTime?       @map("synced_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("inventory_transactions")
}

model Device {
  id         String    @id
  name       String
  lastSyncAt DateTime? @map("last_sync_at")

  @@map("devices")
}

enum IncidentReason {
  OUT_OF_STOCK
  PRICE_TOO_HIGH
  NOT_AVAILABLE
  OTHER
}

model Incident {
  id          String         @id @default(uuid())
  productId   String?        @map("product_id")
  productName String         @map("product_name")
  reason      IncidentReason
  note        String?
  deviceId    String         @map("device_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  syncedAt    DateTime?      @map("synced_at")

  product Product? @relation(fields: [productId], references: [id])

  @@map("incidents")
}

model StoreSettings {
  id           String  @id @default("singleton")
  companyName  String  @default("My Business") @map("company_name")
  tagline      String  @default("")
  logoDataUrl  String  @default("") @map("logo_data_url")
  primaryColor String  @default("#2563eb") @map("primary_color")
  currency     String  @default("KES")
  footerText   String  @default("Thank you for your business.") @map("footer_text")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("store_settings")
}
